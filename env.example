# Copy to `.env.local` and restart the dev server (`npm run dev`).

# Origin only — no trailing `/api` or `/api/v1`
BACKEND_URL=https://grantos-backend-9f5v.onrender.com

# Client-side API base (relative = use Next.js proxy; or set full URL for direct calls)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Deployed contracts on Arbitrum
NEXT_PUBLIC_GRANT_FACTORY_ADDRESS=0xb1fb4eda99821db96cb830413bfb3b18eb67b05f
NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=0xaf2b31d9b6d10010d32bc99d69807c8da2a3894d
NEXT_PUBLIC_GRANT_ESCROW_ADDRESS=0xf45be567e8dfe3982c3e40eb20b47124b626ce2c
NEXT_PUBLIC_VERIFIER_ADDRESS=0x888573502e6766744e28f447d1c44536f0d2cddd
NEXT_PUBLIC_SENTINEL_EAS_ADDRESS=0x6d19b30ce66ea738f906f8daf032aeb273e83b5a

# External dependencies on Arbitrum Sepolia
NEXT_PUBLIC_SABLIER_V2_ADDRESS=0x483bdd560dE53DC20f72dC66ACdB622C5075de34
NEXT_PUBLIC_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
NEXT_PUBLIC_EAS_CONTRACT_ADDRESS=0x2521021fc8BF070473E1e1801D3c7B4aB701E1dE

# ──────────────────────────────────────────────────────────────────────────
# Stellar / Soroban (ZK identity verification on Stellar testnet)
# ──────────────────────────────────────────────────────────────────────────
# Chain is auto-selected at runtime by which wallet the user connects (EVM
# wallet -> EVM flow; Freighter -> Stellar flow). This only sets the default
# before any wallet is connected.
NEXT_PUBLIC_CHAIN_TARGET=evm

NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Deployed Soroban contract ids (live on testnet — see GrantOS-Soroban/DEPLOYED.md)
NEXT_PUBLIC_STELLAR_REGISTRY_ID=CAMNX37PTIPANXVJAJAYU3XHZZDSD3HJRGSENAHBRF73IWMHFA4PCCHE
