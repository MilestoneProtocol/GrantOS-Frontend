# Copy to `.env.local` and restart the dev server (`npm run dev`).

# Origin only — no trailing `/api` or `/api/v1`
BACKEND_URL=https://grantos-backend-9f5v.onrender.com

# Client-side API base (relative = use Next.js proxy; or set full URL for direct calls)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Deployed contracts on Arbitrum
NEXT_PUBLIC_GRANT_FACTORY_ADDRESS=0xb1fb4eda99821db96cb830413bfb3b18eb67b05f
